# Copy this to .env and fill in your keys. The agent loads .env automatically.

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...

# --- LangSmith tracing (optional but recommended) ---
# When set, every agent run is traced to https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=university-qa

# --- Database (optional) ---
# Any SQLAlchemy URL; defaults to sqlite:///university.db
DATABASE_URL=sqlite:///university.db
