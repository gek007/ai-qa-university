# Copy this to .env and fill in your keys. The agent loads .env automatically.

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...

# --- LangSmith tracing (optional but recommended) ---
# When set, every agent run is traced to https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-qa-university

# --- Database (optional) ---
# Any SQLAlchemy URL. Defaults to sqlite:///<project>/data/university.db
# (the `data/` folder is auto-created on first use).
DATABASE_URL=sqlite:///data/university.db


# --- Logging (optional) ---
# LOG_LEVEL=INFO
# Use DEBUG to see per-query DB logs, SQL char counts, and graph build details.
# LOG_TO_CONSOLE=true
# LOG_STREAM=stdout
# File logging: rotating file(s), max 10 backup files (see README).
# LOG_TO_FILE=false
# LOG_FILE=logs/ai-qa-university.log
# LOG_MAX_BYTES=1048576
# LOG_BACKUP_COUNT=10
